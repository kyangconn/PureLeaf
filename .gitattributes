# Auto-detect text files and normalize line endings to LF on commit.
* text=auto

# Source files
*.cpp   text diff=cpp
*.h     text diff=cpp
*.hpp   text diff=cpp
*.c     text diff=c
*.cmake text
CMakeLists.txt      text
CMakePresets.json   text
*.yml   text
*.yaml  text
*.json  text
*.ts    text

# Qt translation files
*.ts    text

# Windows-specific (CRLF in working tree)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.nsi   text eol=crlf

# Images (binary)
*.png   binary
*.ico   binary
*.icns  binary
*.svg   binary

# Archives / packages
*.zip   binary
*.tar.gz binary
